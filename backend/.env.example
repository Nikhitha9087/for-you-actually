# Copy this file to `.env` and fill in your keys. `.env` is gitignored.
#
# The app SHIPS WITH A PREBUILT CATALOGUE, so it runs with NO keys at all:
# local search, feel-matching, and template "why you'll like this" lines all work offline.
# Keys only UNLOCK richer features:
#   - TMDB_API_KEY   : only needed to (re)build the catalogue from scratch (admin ingest).
#   - GROQ_API_KEY   : primary LLM for real "why you'll like this" blurbs + the taste mirror.
#   - GEMINI_API_KEY : embeddings (for onboarding picks not already in the catalogue) and
#                      the generation fallback if Groq is unset/unavailable.

TMDB_API_KEY=
GEMINI_API_KEY=
# Free key, no card: https://console.groq.com/keys  (blank = fall back to Gemini, then template)
GROQ_API_KEY=
